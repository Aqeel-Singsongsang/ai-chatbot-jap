# ======= HUGGING FACE SPACES ENVIRONMENT SECRETS =======
# Salin 3 kunci ini ke tab "Settings -> Variables and secrets" di Hugging Face Space Anda

# 1. API Key untuk Llama-3/Whisper (Wajib)
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXX"

# 2. Database Neon DB URL (Wajib untuk Persistence)
DATABASE_URL="postgresql://neondb_owner:password_anda@domain.aws.neon.tech/neondb?sslmode=require"

# 3. Kunci Rahasia JWT (Terserah Anda, isi kata sandi acak yang panjang)
JWT_SECRET_KEY="SUDAH_DIGANTI_MENJADI_YANG_RUMIT_123456789"
